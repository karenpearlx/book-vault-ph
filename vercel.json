{
  "trailingSlash": false,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin$", "dest": "/admin.html" },
    { "src": "/browse$", "dest": "/browse.html" },
    { "src": "/contact$", "dest": "/contact.html" },
    { "src": "/coming-soon$", "dest": "/coming-soon.html" },
    { "src": "/payment$", "dest": "/payment.html" },
    { "src": "/book/([^/]+)$", "dest": "/book/index.html" },
    { "src": "/blog/([^/]+)$", "dest": "/blog/post.html" }
  ]
}
